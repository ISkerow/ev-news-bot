BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100your_channel_id
ADMIN_ID=your_admin_id
MANAGER_URL=https://t.me/your_manager_username
# DB_PATH=/data/news_production.db  # optional: custom database location (e.g. a mounted volume)
# QUIET_HOURS=23-7                  # optional: no posts during these hours (in TIMEZONE local time)
# TIMEZONE=Asia/Almaty              # IANA timezone for quiet hours, default UTC
# GEMINI_API_KEY=your_key_here      # optional: AI rewrite of posts (aistudio.google.com); unset = plain translation
# GEMINI_MODEL=gemini-2.5-flash     # optional: Gemini model for the rewrite
# MAX_POSTS_PER_DAY=6               # optional: daily post cap (per TIMEZONE day); unset = unlimited
# MAX_NEWS_AGE_HOURS=24             # optional: never publish articles older than this (default 24, 0 = off)
